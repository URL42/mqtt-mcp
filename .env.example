# Copy to .env (compose reads it automatically). Match the credentials you
# created with mosquitto_passwd, see README.
MQTT_USERNAME=mqtt
MQTT_PASSWORD=change-me

# Host-side port for the MCP endpoint, only if 8000 is already taken on this
# machine. The container always listens on 8000 internally regardless.
# MCP_HOST_PORT=8090

# Only needed when running server.py outside compose (local dev):
# MQTT_HOST=192.168.1.50
# MQTT_PORT=1883
# MCP_PORT=8000
# CMD_PREFIX=cmd/
