# Copy to .env (compose reads it automatically). Match the credentials you
# created with mosquitto_passwd, see README.
MQTT_USERNAME=mqtt
MQTT_PASSWORD=change-me

# Host-side ports, only needed if the defaults are already taken on this
# machine. The containers always listen on 8000 (MCP) and 1883 (broker)
# internally regardless; these only change the LAN-facing published ports.
# Devices connect to the broker at <host>:<MQTT_HOST_PORT>.
# MCP_HOST_PORT=8090
# MQTT_HOST_PORT=1884

# Only needed when running server.py outside compose (local dev):
# MQTT_HOST=192.168.1.50
# MQTT_PORT=1883
# MCP_PORT=8000
# CMD_PREFIX=cmd/
