# Copy to .env (compose reads it automatically). Match the credentials you
# created with mosquitto_passwd, see README.
MQTT_USERNAME=mqtt
MQTT_PASSWORD=change-me

# Only needed when running server.py outside compose (local dev):
# MQTT_HOST=192.168.1.50
# MQTT_PORT=1883
# MCP_PORT=8000
# CMD_PREFIX=cmd/
